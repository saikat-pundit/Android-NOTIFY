<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:gravity="center">

    <LinearLayout
        android:id="@+id/calculatorLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:maxWidth="450dp"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="visible">

        <TextView
            android:id="@+id/calcDisplay"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="4"
            android:gravity="bottom|end"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textSize="42sp"
            android:scrollbars="vertical"
            android:paddingBottom="24dp"/>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="6"
            android:columnCount="4"
            android:rowCount="5"
            android:layout_marginBottom="16dp">

            <Button android:id="@+id/btnC" android:text="C" android:textColor="#FF5252" style="@style/CalcButton"/>
            <Button android:id="@+id/btnOpenBracket" android:text="(" android:textColor="#4CAF50" style="@style/CalcButton"/>
            <Button android:id="@+id/btnCloseBracket" android:text=")" android:textColor="#4CAF50" style="@style/CalcButton"/>
            <Button android:id="@+id/btnDel" android:text="DEL" android:textColor="#FF5252" style="@style/CalcButton"/>

            <Button android:id="@+id/btn7" android:text="7" style="@style/CalcButton"/>
            <Button android:id="@+id/btn8" android:text="8" style="@style/CalcButton"/>
            <Button android:id="@+id/btn9" android:text="9" style="@style/CalcButton"/>
            <Button android:id="@+id/btnDiv" android:text="÷" android:textColor="#4CAF50" style="@style/CalcButton"/>

            <Button android:id="@+id/btn4" android:text="4" style="@style/CalcButton"/>
            <Button android:id="@+id/btn5" android:text="5" style="@style/CalcButton"/>
            <Button android:id="@+id/btn6" android:text="6" style="@style/CalcButton"/>
            <Button android:id="@+id/btnMul" android:text="×" android:textColor="#4CAF50" style="@style/CalcButton"/>

            <Button android:id="@+id/btn1" android:text="1" style="@style/CalcButton"/>
            <Button android:id="@+id/btn2" android:text="2" style="@style/CalcButton"/>
            <Button android:id="@+id/btn3" android:text="3" style="@style/CalcButton"/>
            <Button android:id="@+id/btnSub" android:text="-" android:textColor="#4CAF50" style="@style/CalcButton"/>

            <Button android:id="@+id/btnDot" android:text="." style="@style/CalcButton"/>
            <Button android:id="@+id/btn0" android:text="0" style="@style/CalcButton"/>
            <Button android:id="@+id/btnPercent" android:text="%" android:textColor="#4CAF50" style="@style/CalcButton"/>
            <Button android:id="@+id/btnAdd" android:text="+" android:textColor="#4CAF50" style="@style/CalcButton"/>

            <Button android:id="@+id/btnEquals" android:text="=" android:backgroundTint="#4CAF50" android:layout_columnSpan="4" android:layout_gravity="fill_horizontal" style="@style/CalcButton"/>
        </GridLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/mainContentLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">
            
            <Button
                android:id="@+id/btnTabPermissions"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Permissions"
                android:backgroundTint="#4CAF50"
                android:textColor="#FFFFFF"
                android:layout_marginEnd="2dp"
                android:textSize="12sp"/>
                
            <Button
                android:id="@+id/btnTabLogs"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Notify Log"
                android:backgroundTint="#333333"
                android:textColor="#FFFFFF"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:textSize="12sp"/>

            <Button
                android:id="@+id/btnTabUsage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Usage Log"
                android:backgroundTint="#333333"
                android:textColor="#FFFFFF"
                android:layout_marginStart="2dp"
                android:textSize="12sp"/>
        </LinearLayout>

        <ScrollView
            android:id="@+id/containerPermissions"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <Button android:id="@+id/btnPermNotif" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="❌ Notification Access" android:layout_marginBottom="8dp"/>
                <Button android:id="@+id/btnPermOverlay" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="❌ Display Over Other Apps" android:layout_marginBottom="8dp"/>
                <Button android:id="@+id/btnPermWrite" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="❌ Modify System Settings" android:layout_marginBottom="8dp"/>
                <Button android:id="@+id/btnPermDND" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="❌ Do Not Disturb Access" android:layout_marginBottom="8dp"/>
                <Button android:id="@+id/btnPermUsage" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="❌ Usage Data Access" android:layout_marginBottom="8dp"/>
                <Button android:id="@+id/btnPermBattery" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="❌ Ignore Battery Optimization" android:layout_marginBottom="8dp"/>
                <Button android:id="@+id/btnPermAlarm" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="❌ Exact Alarms" android:layout_marginBottom="8dp"/>
                <Button android:id="@+id/btnPermPost" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="❌ Post Notifications (A13+)" android:layout_marginBottom="8dp"/>
                <Button android:id="@+id/btnPermData" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="❌ Unrestricted Data Usage" android:layout_marginBottom="8dp"/>
                <Button android:id="@+id/btnAdmin" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="❌ Uninstall Protection" android:layout_marginBottom="24dp"/>
                <Button android:id="@+id/btnAutoStart" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="⚙️ OEM AutoStart Settings" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:layout_marginBottom="24dp"/>
                <Button android:id="@+id/btnStartServices" android:layout_width="match_parent" android:layout_height="wrap_content" android:backgroundTint="#4CAF50" android:textColor="#FFFFFF" android:text="🚀 START SYSTEM SERVICES" android:textStyle="bold" android:layout_marginBottom="24dp"/>
            </LinearLayout>
        </ScrollView>

        <LinearLayout
            android:id="@+id/containerLogs"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="8dp">
                <TextView
                    android:id="@+id/logTextView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#E0E0E0" 
                    android:fontFamily="monospace" 
                    android:textSize="13sp"
                    android:text="Waiting for data..."/>
            </ScrollView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <Button 
                    android:id="@+id/btnRefresh" 
                    android:layout_width="0dp" 
                    android:layout_weight="1" 
                    android:layout_height="wrap_content" 
                    android:layout_marginEnd="4dp" 
                    android:backgroundTint="#222222" 
                    android:textColor="#FFFFFF" 
                    android:text="🔄 Refresh" />
                <Button 
                    android:id="@+id/btnClear" 
                    android:layout_width="0dp" 
                    android:layout_weight="1" 
                    android:layout_height="wrap_content" 
                    android:layout_marginStart="4dp" 
                    android:backgroundTint="#8B0000" 
                    android:textColor="#FFFFFF" 
                    android:text="🗑️ Clear Local" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/containerUsage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="8dp">
                <TextView
                    android:id="@+id/usageLogTextView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#E0E0E0" 
                    android:fontFamily="monospace" 
                    android:textSize="13sp"
                    android:text="Waiting for app usage data..."/>
            </ScrollView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <Button 
                    android:id="@+id/btnRefreshUsage" 
                    android:layout_width="0dp" 
                    android:layout_weight="1" 
                    android:layout_height="wrap_content" 
                    android:layout_marginEnd="4dp" 
                    android:backgroundTint="#222222" 
                    android:textColor="#FFFFFF" 
                    android:text="🔄 Refresh" />
                <Button 
                    android:id="@+id/btnClearUsage" 
                    android:layout_width="0dp" 
                    android:layout_weight="1" 
                    android:layout_height="wrap_content" 
                    android:layout_marginStart="4dp" 
                    android:backgroundTint="#8B0000" 
                    android:textColor="#FFFFFF" 
                    android:text="🗑️ Clear Local" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</RelativeLayout>
